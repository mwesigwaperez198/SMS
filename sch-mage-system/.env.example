# NovaAdmin API - Environment Configuration

# JWT & Security
SECRET_KEY=change-this-to-a-64-char-hex-string
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+pysqlite:///./novaadmin.db
# For MariaDB:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/novaadmin?charset=utf8mb4
DB_AUTO_CREATE=True
SEED_DEMO_DATA=True

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Token Configuration
ACCESS_TOKEN_EXPIRE_DAYS=1
REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!
